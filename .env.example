R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=photoflow
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Public URL for R2 bucket (used by the website at build time)
NEXT_PUBLIC_R2_URL=https://pub-xxx.r2.dev

# Source directory for photos (Lightroom export folder)
PHOTOS_SOURCE_DIR="D:\site-photos"
